{
  "name": "Didactic_Series",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://pthfndr.online/didactics/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:didactics": "VITE_BASE_PATH=/didactics/ VITE_OUT_DIR=dist/didactics vite build && node scripts/configure_didactics_pages.cjs",
    "sync:didactics-tunnel": "npm run build:didactics && rsync -a --delete dist/ /Users/ski_mini/.cloudflared/pthfndr-didactics-dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "sync:legacy-manifest": "node scripts/sync_legacy_image_manifest.cjs",
    "breast:validate-assets": "node scripts/validate_breast_signout_assets.cjs",
    "breast:acquire-assets:self-test": "node scripts/acquire_breast_signout_assets.cjs --self-test",
    "ap:generate-contract": "node scripts/generate_ap_signout_contract.cjs",
    "ap:validate-contract": "node scripts/validate_ap_signout_contract.cjs",
    "ap:acquire-assets:self-test": "node scripts/acquire_ap_signout_assets.cjs --self-test",
    "gu:validate-sims": "node scripts/validate_gu_signout_sims.cjs",
    "signout:validate-sims": "node scripts/validate_specialty_signout_sims.cjs",
    "signout:validate-ux": "node scripts/validate_signout_ux_journey.cjs",
    "signout:import-local-images": "node scripts/import_local_signout_images.cjs",
    "signout:acquire-pubmed-oa-images": "node scripts/acquire_pubmed_oa_signout_images.cjs",
    "signout:index-images": "node scripts/generate_signout_image_reference_index.cjs",
    "reference:import-apcpboards": "node scripts/import_apcpboards_reference_images.cjs",
    "ap:gaps:plan": "node scripts/generate_ap_gap_closure_plan.cjs",
    "ap:gaps:cards": "npm run ap:gaps:plan && node scripts/generate_ap_p0_entity_cards.cjs",
    "ap:gaps:cards:cv-autopsy": "node scripts/generate_ap_p0_cv_autopsy_cards.cjs",
    "ap:gaps:cards:endocrine": "node scripts/generate_ap_p0_endo_cards.cjs",
    "ap:gaps:cards:dermpath": "node scripts/generate_ap_p0_dermpath_cards.cjs",
    "ap:gaps:cards:all": "npm run ap:gaps:cards && npm run ap:gaps:cards:cv-autopsy && npm run ap:gaps:cards:endocrine && npm run ap:gaps:cards:dermpath",
    "ap:gaps:validate-cards": "node scripts/validate_ap_p0_entity_cards.cjs",
    "ap:gaps:validate-batches": "node scripts/validate_ap_p0_batches.cjs",
    "ap:gaps:status": "node scripts/generate_ap_p0_batch_status_report.cjs",
    "ap:gaps:verify": "npm run ap:gaps:validate-cards && npm run ap:gaps:validate-batches && npm run ap:gaps:status",
    "images:crawl-entity-histology": "node scripts/crawl_entity_histology_images.cjs",
    "neuro:import-jh-atlas-metadata": "node scripts/import_jh_neuro_atlas_metadata.cjs",
    "images:validate-local": "node scripts/validate_app_local_images.cjs",
    "images:validate-rendered": "node scripts/validate_rendered_image_placeholders.cjs",
    "neuro:import-authorized-images": "node scripts/import_authorized_neuro_atlas_images.cjs",
    "batch:next-10": "node scripts/run_next_ten_migration_steps.cjs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:didactics": "npm run build:didactics && gh-pages -d dist"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "clsx": "^2.0.0",
    "konva": "^9.3.6",
    "lucide-react": "^0.294.0",
    "openseadragon": "^5.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.1.0",
    "use-image": "^1.1.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "dotenv": "^16.3.1",
    "gh-pages": "^6.0.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "rollup": "^4.52.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "brace-expansion": "^2.0.3",
    "glob": "^10.5.0",
    "minimatch": "^9.0.7",
    "picomatch": "^2.3.2"
  }
}
